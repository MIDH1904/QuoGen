{
  "name": "roshni-solar-quotation-gen",
  "version": "1.0.0",
  "description": "Full-stack web application to generate solar rooftop quotation PDFs for Roshni Solar",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix frontend",
    "install-all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "puppeteer": "^22.6.0",
    "puppeteer-core": "^22.6.0",
    "@sparticuz/chromium": "^122.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  },
  "private": true
}
